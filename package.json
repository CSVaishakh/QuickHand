{
    "name": "quickhand-monorepo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "bun run dev:backend & bun run dev:web",
        "dev:backend": "bun run --cwd apps/backend dev",
        "dev:web": "bun run --cwd apps/web next dev",
        "dev:full": "bun run db:start && bun run dev",
        "db:start": "docker compose -f packages/db/docker-compose.yml up -d postgres",
        "db:stop": "docker compose -f packages/db/docker-compose.yml stop postgres",
        "db:shell": "docker exec -it QuickHand-postgres psql -U user -d QuickHand-DB",
        "db:generate": "bun --env-file=.env.local run --cwd packages/db generate",
        "db:push": "bun --env-file=.env.local run --cwd packages/db push",
        "db:studio": "bun --env-file=.env.local run --cwd packages/db studio",
        "db:reset": "docker compose -f packages/db/docker-compose.yml down -v && docker compose -f packages/db/docker-compose.yml up -d postgres && sleep 3 && bun run db:generate && bun run db:push"
    },
    "devDependencies": {
        "drizzle-kit": "^0.31.10"
    },
    "overrides": {
        "drizzle-orm": "^0.45.0"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@types/node": "^25.8.0",
        "better-auth": "^1.6.11",
        "react-hook-form": "^7.76.0",
        "swr": "^2.4.1",
        "zod": "^4.4.3"
    }
}
